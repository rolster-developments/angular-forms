{
  "name": "@rolster/angular-forms",
  "version": "19.5.3",
  "type": "module",
  "description": "It implements a set of classes that allow managing the control of states of the input components in Angular",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.cjs",
        "import": "./dist/es/index.mjs"
      },
      "default": "./dist/es/index.mjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/**/*.{ts}\"",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p tsconfig.app.json && rollup -c rollup.config.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@angular/core": "^17.3.12 || ^18.2.14 || ^19.2.19",
    "@rolster/forms": "^4.1.4",
    "@rolster/validators": "^3.1.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolster/rollup": "^2.1.0",
    "@rolster/types": "^1.1.1",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.7.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.1.8",
    "rimraf": "^6.1.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-angular-forms.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "angular",
    "forms"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
}
